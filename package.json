{
  "name": "flue-tui",
  "version": "0.1.0",
  "description": "interactive terminal chat client for flue agents",
  "repository": "https://github.com/cfahlgren1/flue-tui",
  "homepage": "https://github.com/cfahlgren1/flue-tui#readme",
  "bugs": {
    "url": "https://github.com/cfahlgren1/flue-tui/issues"
  },
  "author": "Caleb Fahlgren",
  "keywords": [
    "flue",
    "agent",
    "tui",
    "terminal",
    "chat",
    "ai"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "flue-tui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e --fileParallelism=false",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "0.80.10",
    "@flue/sdk": "1.0.0-beta.9",
    "chalk": "^5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^3"
  },
  "packageManager": "pnpm@10.12.1"
}
