{
  "name": "flue-tui",
  "version": "0.1.0",
  "description": "interactive terminal chat client for flue agents",
  "keywords": [
    "agent",
    "ai",
    "chat",
    "flue",
    "terminal",
    "tui"
  ],
  "homepage": "https://github.com/cfahlgren1/flue-tui#readme",
  "bugs": {
    "url": "https://github.com/cfahlgren1/flue-tui/issues"
  },
  "license": "Apache-2.0",
  "author": "Caleb Fahlgren",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cfahlgren1/flue-tui.git"
  },
  "bin": {
    "flue-tui": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm clean && tsc",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean": "node scripts/clean.mjs",
    "dev": "tsx src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e --fileParallelism=false",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "0.80.10",
    "@flue/sdk": "1.0.0-beta.9",
    "chalk": "^5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4",
    "typescript": "^5.6",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@10.12.1"
}
